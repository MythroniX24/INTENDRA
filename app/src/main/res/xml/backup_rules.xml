<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup Rules (legacy — Android < 12 / API < 31)
  Companion to data_extraction_rules.xml for older API levels.

  Policy: EXCLUDE everything. INTERNDRA is local-first and private.
  No user data should ever leave the device via Android's backup system.
-->
<full-backup-content>
    <exclude domain="root"       path="." />
    <exclude domain="file"       path="." />
    <exclude domain="database"   path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external"   path="." />
</full-backup-content>
