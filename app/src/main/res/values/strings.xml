    <!-- ── Accessibility service ────────────────────────────────────── -->
    <string name="accessibility_service_label">INTERNDRA AI Agent</string>
    <string name="accessibility_service_description">
        Enables INTERNDRA to perform UI automation tasks on your behalf —
        such as tapping buttons, filling forms, and navigating apps —
        only when you explicitly issue a command.\n\n
        INTERNDRA does not read, record, or transmit the content of
        other apps\' screens or text fields.
    </string>
    <string name="accessibility_service_summary">
        AI-driven UI automation for INTERNDRA commands
    </string>

    <!-- ── Notification listener ─────────────────────────────────────── -->
    <string name="notification_listener_label">INTERNDRA Automation Triggers</string>
    <string name="notification_listener_description">
        Monitors incoming notifications to trigger automations you have
        set up (e.g., "when I get a WhatsApp message, reply with X").\n\n
        INTERNDRA logs only the app name and notification title —
        never the notification body or message content.
    </string>

